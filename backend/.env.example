# Copy to .env and fill in values — never commit .env to git

# Supabase
SUPABASE_URL=https://etrevvjzybjbceowmxjl.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here   # Project Settings → API → service_role

# CORS — comma-separated origins
ALLOWED_ORIGINS=http://localhost:8081,https://your-app.com

# Redis (Railway Redis add-on — auto-set in Railway env)
REDIS_URL=redis://localhost:6379

# Cloudflare R2 (for model CDN + 3D assets)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_MODELS=chadongcha-models
R2_BUCKET_ASSETS=chadongcha-assets
R2_PUBLIC_URL=https://your-r2-public-url.com

# Satellite tracking
CELESTRAK_BASE_URL=https://celestrak.org/SOCRATES/query.php
SPACETRACK_USER=your-spacetrack-username
SPACETRACK_PASS=your-spacetrack-password

# App
APP_ENV=development    # development | production
MODEL_CURRENT_VERSION=0.0.1
